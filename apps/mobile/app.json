{
  "expo": {
    "name": "OrderKaro",
    "slug": "orderkaro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "orderkaro",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#DC2626"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.orderkaro.app",
      "infoPlist": {
        "NSCameraUsageDescription": "OrderKaro needs camera access to scan QR codes at tables"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#DC2626"
      },
      "package": "com.orderkaro.app",
      "permissions": ["CAMERA"]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "OrderKaro needs camera access to scan QR codes at tables"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
